.pulse-border-icon {
    animation-name: color-border-icon;
    animation-duration: 2s;
    animation-iteration-count: infinite;
}

@keyframes color-border-icon {
    0% {
        background-color: transparent;
    }

    20% {
        background-color: #999;
    }

    40% {
        background-color: transparent;
    }

    100% {
        background-color: transparent;
    }
}